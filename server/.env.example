PORT=8787

# Optional — leave empty to disable Web Push routes (503). Welfare API still runs.
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.example

# Comma-separated browser origins allowed to call the API (recommended in production).
CORS_ORIGIN=http://localhost:4173,http://localhost:5173

# If set, POST /welfare/analyze and POST /welfare/contribute require:
#   Authorization: Bearer <API_SHARED_TOKEN>   OR   X-Link-Help-Api-Token: <API_SHARED_TOKEN>
# Leave unset for local dev only (endpoints are open).
# API_SHARED_TOKEN=

# OpenAI — when set, POST /welfare/analyze uses chat completions; otherwise heuristic only.
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Google Programmable Search (Custom Search JSON API) — for POST /welfare/discover-web from the app.
# Create a search engine at https://programmablesearchengine.google.com/ (search entire web).
# API key: https://developers.google.com/custom-search/v1/introduction
# GOOGLE_SEARCH_API_KEY=
# GOOGLE_SEARCH_ENGINE_ID=

# If set, POST /push/send must send header: X-Link-Help-Admin: <same value>
# ADMIN_PUSH_SECRET=
